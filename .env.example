# slowquery-demo-backend
#
# Copy to .env and fill in every non-commented line. `.env` is git-ignored.

# --- runtime ---
APP_ENV=development                                       # development | production
LOG_LEVEL=info                                            # debug | info | warning | error
PORT=8000
DEMO_MODE=true                                            # demo mode accepts any X-Platform-Token

# --- Neon Postgres (two branches for the live slow/fast switch) ---
# The `slowquery` branch is seeded without indexes (1M orders, 5M order_items).
# The `slowquery-fast` branch has the same rows + the 3 missing indexes added.
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/slowquery?sslmode=require
DATABASE_URL_FAST=postgresql+asyncpg://USER:PASS@HOST/slowquery-fast?sslmode=require
BRANCH_CURRENT=slow                                       # slow | fast

# --- slowquery-detective middleware tunables ---
SLOWQUERY_THRESHOLD_MS=100                                # any query > this is captured
SLOWQUERY_SAMPLE_RATE=1.0                                 # 0.0-1.0; 1.0 = sample every call
SLOWQUERY_STORE_URL=                                      # defaults to DATABASE_URL when blank

# --- Neon API (for POST /branches/switch live branch swap) ---
NEON_API_KEY=
NEON_PROJECT_ID=

# --- OpenRouter LLM fallback (for the rules-engine explainer) ---
LLM_FALLBACK_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=                                 # picked at integration time

# --- CORS ---
CORS_ORIGINS=https://slowquery-dashboard-frontend.vercel.app,http://localhost:3000
